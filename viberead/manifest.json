{
  "manifest_version": 3,
  "name": "VibeRead — Speed Reader & PDF",
  "short_name": "VibeRead",
  "version": "1.0.1",
  "description": "RSVP speed-reading with native PDF support, auto-resume, and beautiful dark UI.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "reader/reader.html",
        "pdf/pdf-reader.html",
        "lib/*",
        "icons/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "open-reader": {
      "suggested_key": {
        "default": "Alt+V"
      },
      "description": "VibeRead current page"
    }
  }
}
